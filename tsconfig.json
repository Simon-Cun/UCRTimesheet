{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@api/*": ["./api/*"]
    }
  },
  "include": ["backend/server.ts", "api/**/*"],
  "exclude": ["node_modules"]
}
